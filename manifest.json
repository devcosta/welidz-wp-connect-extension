{
  "manifest_version": 3,
  "name": "Welidz WhatsApp Connect",
  "version": "0.0.1",
  "description": "Connect Welidz directly to your WhatsApp Web simply and quickly.",
  "icons": {
    "16": "src/ui/assets/icon_16.png",
    "32": "src/ui/assets/icon_32.png",
    "48": "src/ui/assets/icon_48.png",
    "128": "src/ui/assets/icon_128.png"
  },
  "action": {
    "default_popup": "src/ui/popup/index.html",
    "default_icon": "src/ui/assets/icon_48.png"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/entries/background/main.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "src/entries/content/whatsapp.ts"
      ]
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "*://*.welidz.com/*"
      ],
      "js": [
        "src/entries/content/saas.ts"
      ]
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "*://*.welidz.com/*"
    ]
  }
}